{
  "name": "VercelCheck (Python 3.11)",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bullseye",
  "customizations": {
    "codespaces": {
      "openFiles": ["README.md", "streamlit_app.py"]
    },
    "vscode": {
      "settings": {},
      "extensions": ["ms-python.python", "ms-python.vscode-pylance"]
    }
  },
  "updateContentCommand": "pip3 install --user -r requirements.txt && python3 -m playwright install --with-deps chromium && echo '✅ VercelCheck ready'",
  "postAttachCommand": {
    "server": "streamlit run streamlit_app.py --server.enableCORS false --server.enableXsrfProtection false"
  },
  "portsAttributes": {
    "8501": { "label": "VercelCheck", "onAutoForward": "openPreview" }
  },
  "forwardPorts": [8501]
}
